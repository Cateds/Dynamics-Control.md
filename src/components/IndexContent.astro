---
import { Card, CardGrid } from "@astrojs/starlight/components";

interface Article {
  id: string;
  data: {
    title: string;
    description: string;
  };
}

interface Grouped {
  [key: string]: Article[];
}

const { grouped } = Astro.props as { grouped: Grouped };
---

<style>
  .card-grid :global(.card-grid) {
    align-items: start;
  }
  .card-grid :global(.card) {
    align-self: start;
    height: auto;
  }
</style>

{
  Object.entries(grouped).map(([part, articles]: [string, Article[]]) => (
    <div class="part-section">
      <div
        class="part-title"
        onclick="this.parentElement.classList.toggle('collapsed')"
      >
        <svg
          class="chevron"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
        {part}
      </div>
      <div class="part-content">
        <div class="card-grid">
          <CardGrid stagger>
            {articles.map((article: Article) => (
              <Card title={article.data.title} icon="open-book">
                {article.data.description}
                <br /> <br />
                <a href={article.id}>前往阅读</a>
              </Card>
            ))}
          </CardGrid>
        </div>
      </div>
    </div>
  ))
}
